# Email alert credentials (copy to src/.env and fill in — src/.env is gitignored).
# Gmail requires 2-Step Verification + an App Password (not your normal password):
#   Google Account → Security → App passwords
ALERT_RECEIVER_EMAIL=you@example.com
ALERT_SENDER_EMAIL=you@example.com
ALERT_SENDER_PASS=your_16_char_app_password
