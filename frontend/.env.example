# Transport selection: "ws" (live backend) or "mock" (in-browser simulator).
# Defaults to "mock" so the UI runs with zero backend dependencies.
VITE_TRANSPORT=mock

# Backend endpoints (used when VITE_TRANSPORT=ws).
# Leave host empty to use same-origin + Vite dev proxy (see vite.config.ts).
VITE_WS_URL=/ws/stream
VITE_API_BASE=/api
