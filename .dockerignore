.venv
**/__pycache__
**/*.pyc
node_modules
frontend/node_modules
frontend/dist
# Exclude the multi-hundred-MB datasets, but keep the small demo CSVs so the
# single-container image (Dockerfile.hf) can bundle them.
data/*
!data/attack.csv
!data/normal_sample.csv
# models/*.h5 are tiny (~76KB) and required for real inference — keep them.
logs
.git
*.bak
# Never bake secrets into the image — injected at runtime via compose env_file.
src/.env
.env
